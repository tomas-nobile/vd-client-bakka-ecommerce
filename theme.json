				},
				{
					"slug": "tertiary",
					"color": "#E694FF",
					"name": "Tertiary"
				},
				{
					"slug": "cta",
					"color": "#1E6AFF",
					"name": "CTA"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontSizes": [
				{
					"fluid": false,
