{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "etheme/core-navbar",
	"version": "0.1.0",
	"title": "core.Navigation Bar",
	"category": "widgets",
	"icon": "menu",
	"description": "A responsive navigation bar with dynamic menu items and icons.",
	"example": {},
	"attributes": {
		"logoUrl": {
			"type": "string",
			"default": ""
		},
		"menuItems": {
			"type": "array",
			"default": [
				{ "label": "Inicio", "url": "/" },
				{ "label": "Tienda", "url": "/?post_type=product" },
				{ "label": "Posteos", "url": "/?page_id=51" }
			]
		},
		"searchUrl": {
			"type": "string",
			"default": "#"
		},
		"cartUrl": {
			"type": "string",
			"default": "#"
		},
		"accountUrl": {
			"type": "string",
			"default": "#"
		}
	},
	"supports": {
		"html": false
	},
	"textdomain": "navbar",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
