{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "etheme/core-navbar",
	"version": "0.1.0",
	"title": "Navbar",
	"category": "theme",
	"icon": "menu",
	"description": "Barra de navegación con menú WP, árbol product_cat automático, menú móvil fullscreen y búsqueda modal.",
	"example": {},
	"supports": {
		"html": false
	},
	"attributes": {
		"menuLocation": {
			"type": "string",
			"default": "etheme-primary"
		},
		"showSearch": {
			"type": "boolean",
			"default": true
		},
		"showCart": {
			"type": "boolean",
			"default": true
		}
	},
	"textdomain": "etheme",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
