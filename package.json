{
	"name": "0_block",
	"version": "0.1.0",
	"description": "Example block scaffolded with Create Block tool.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "npm-run-all --sequential buildwp tailwindbuild",
		"build:prod": "bash ./scripts/build-prod.sh",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "bash ./scripts/start-dev.sh",
		"start:watch": "npm-run-all --parallel wpstart tailwindwatch",
		"buildwp": "wp-scripts build --webpack-copy-php --blocks-manifest",
		"wpstart": "wp-scripts start --webpack-copy-php --blocks-manifest",
		"tailwindbuild": "tailwindcss -i ./src/index.css -o ./build/index.css --minify",
		"tailwindwatch": "tailwindcss -i ./src/index.css -o ./build/index.css --watch --minify",
		"cc": "bash ./scripts/create-component.sh",
		"cb": "bash ./scripts/create-block.sh",
		"db": "bash ./scripts/delete-block.sh"
	},
	"dependencies": {
		"@wordpress/block-editor": "latest",
		"@wordpress/blocks": "latest",
		"@wordpress/i18n": "latest"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.16",
		"@wordpress/scripts": "^30.10.0",
		"browser-sync": "^3.0.3",
		"npm-run-all": "^4.1.5",
		"tailwindcss": "^4.0.6",
		"@tailwindcss/cli": "^4.0.6"
	}
}